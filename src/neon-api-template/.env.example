# Neon connection string (Neon Console → Dashboard)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Data API URL (Neon Console → Settings → Data API)
NEON_DATA_API_URL=https://ep-xxxx.us-east-1.aws.neon.tech/neondb/rest/v1

# JWT signing key: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_EXPIRY_HOURS=24

HOST=0.0.0.0
PORT=8080
RUST_LOG=neon_api=debug,tower_http=debug
